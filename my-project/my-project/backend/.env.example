# Copy to .env and fill in. NEVER commit .env.
DATABASE_URL=postgres://fluentdev:fluentdev@localhost:5432/fluentdev?sslmode=disable
ADDR=:8080
APP_BASE_URL=http://localhost:5173
OAUTH_REDIRECT_BASE=http://localhost:8080

SESSION_COOKIE_NAME=fluentdev_session
SESSION_TTL=720h
# set true behind TLS (production)
SECURE_COOKIES=false

# Transcription (research R2): groq | openai
TRANSCRIBE_PRIMARY=groq
GROQ_API_KEY=
OPENAI_API_KEY=

# OAuth apps — callback: {OAUTH_REDIRECT_BASE}/api/v1/auth/oauth/{provider}/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
